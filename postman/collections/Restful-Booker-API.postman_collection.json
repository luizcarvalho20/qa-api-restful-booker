            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code deve ser 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type deve conter application/json\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "const responseJson = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Resposta deve conter bookingid\", function () {\r",
                  "    pm.expect(responseJson).to.have.property(\"bookingid\");\r",
                  "    pm.expect(responseJson.bookingid).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta deve conter objeto booking\", function () {\r",
                  "    pm.expect(responseJson).to.have.property(\"booking\");\r",
                  "    pm.expect(responseJson.booking).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Objeto booking deve conter os campos obrigatórios\", function () {\r",
                  "    pm.expect(responseJson.booking).to.have.property(\"firstname\");\r",
                  "    pm.expect(responseJson.booking).to.have.property(\"lastname\");\r",
                  "    pm.expect(responseJson.booking).to.have.property(\"totalprice\");\r",
                  "    pm.expect(responseJson.booking).to.have.property(\"depositpaid\");\r",
                  "    pm.expect(responseJson.booking).to.have.property(\"bookingdates\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Dados retornados devem bater com o enviado\", function () {\r",
                  "    pm.expect(responseJson.booking.firstname).to.eql(\"Luiz\");\r",
                  "    pm.expect(responseJson.booking.lastname).to.eql(\"Carvalho\");\r",
                  "    pm.expect(responseJson.booking.totalprice).to.eql(250);\r",
                  "    pm.expect(responseJson.booking.depositpaid).to.eql(true);\r",
                  "    pm.expect(responseJson.booking.bookingdates.checkin).to.eql(\"2026-03-20\");\r",
                  "    pm.expect(responseJson.booking.bookingdates.checkout).to.eql(\"2026-03-25\");\r",
                  "    pm.expect(responseJson.booking.additionalneeds).to.eql(\"Breakfast\");\r",
                  "});"
                ],
